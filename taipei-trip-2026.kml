  <!-- ==================== -->
  <!-- DAY 1 (5/1) - Blue   -->
  <!-- ==================== -->
  <Folder>
    <name>5/1 (금) 도착 + 단수이</name>
    <Placemark>
      <name>타오위안 국제공항</name>
      <description>도착: 10:55 (지수/희주/우영/영진), 13:35 (원상/현상)</description>
      <styleUrl>#day1</styleUrl>
      <Point><coordinates>121.2342,25.0797,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>홍마오청 (紅毛城)</name>
      <description>14:00 - 스페인 건설, 네덜란드 재건, 영국 영사관. 단수이 랜드마크</description>
      <styleUrl>#day1</styleUrl>
      <Point><coordinates>121.4327,25.1753,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>소백궁 (小白宮)</name>
      <description>14:40 - 하얀 서양식 건물, 포토존</description>
      <styleUrl>#day1</styleUrl>
      <Point><coordinates>121.4312,25.1742,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>진리대학 (真理大學)</name>
      <description>15:10 - 캠퍼스 산책. 17-18시 폐장 주의</description>
      <styleUrl>#day1</styleUrl>
      <Point><coordinates>121.4300,25.1760,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>흑전반점 (黑殿飯店)</name>
      <description>15:30 - 돼지갈비덮밥 맛집. 약 100TWD. 11:00-20:00</description>
      <styleUrl>#day1</styleUrl>
      <Point><coordinates>121.4408,25.1693,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>단수이 페리 선착장</name>
      <description>16:30 - 빠리행 페리 탑승. 편도 23TWD, 약 10분</description>
      <styleUrl>#day1</styleUrl>
      <Point><coordinates>121.4385,25.1710,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>빠리 좌안 (八里左岸)</name>
      <description>17:00 - 자전거 라이딩 + 노을 감상</description>
      <styleUrl>#day1</styleUrl>
      <Point><coordinates>121.4137,25.1717,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>닝샤야시장 (寧夏夜市)</name>
      <description>19:30 - MRT 중산역 도보 10분. 위엔환볜 미슐랭 굴전 필수</description>
      <styleUrl>#day1</styleUrl>
      <Point><coordinates>121.5153,25.0555,0</coordinates></Point>
    </Placemark>
  </Folder>

  <!-- ==================== -->
  <!-- DAY 2 (5/2) - Green  -->
  <!-- ==================== -->
  <Folder>
    <name>5/2 (토) 누가크래커 + 중산 + 시먼딩</name>
    <Placemark>
      <name>라뜰리에 루터스 (L'Atelier de Nougat)</name>
      <description>08:00 오픈런 - 누가크래커. 09시 오픈, 10시 전 품절. 현금만. 1인 10박스 제한</description>
      <styleUrl>#day2</styleUrl>
      <Point><coordinates>121.5293,25.0327,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>중정기념당 (中正紀念堂)</name>
      <description>09:30 - 10시 위병교대식 관람</description>
      <styleUrl>#day2</styleUrl>
      <Point><coordinates>121.5219,25.0350,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>중산 카페거리 / 중산지하서가</name>
      <description>11:00 - 성수/연남 느낌. 독립 카페, 소품샵, 청핀서점</description>
      <styleUrl>#day2</styleUrl>
      <Point><coordinates>121.5225,25.0531,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>시먼딩 (西門町)</name>
      <description>14:00 - 아종면선, 지파이, 리얼58도, 무지개 횡단보도</description>
      <styleUrl>#day2</styleUrl>
      <Point><coordinates>121.5081,25.0424,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>아종면선 (阿宗麵線)</name>
      <description>곱창국수 - 소 65TWD / 대 120TWD. 서서 먹는 곳</description>
      <styleUrl>#day2</styleUrl>
      <Point><coordinates>121.5065,25.0425,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>까르푸 (Carrefour) 구이린점</name>
      <description>21:00 - 기념품 쇼핑. NT$2,000 이상 세금환급 5%</description>
      <styleUrl>#day2</styleUrl>
      <Point><coordinates>121.5050,25.0380,0</coordinates></Point>
    </Placemark>
  </Folder>

